# Diet Pro Planner local environment example.
# Copy this file to .env on your Raspberry Pi and fill your own private values.
# Never commit .env, tokens or local databases.

APP_PORT=8099

# Optional Strava integration.
# Create a Strava API app and use localhost OAuth through an SSH tunnel.
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:8099/api/strava/callback
